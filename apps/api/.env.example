# apps/api environment template. Copy to .env and fill real values (never commit .env).
# Dùng Supabase Connection Pooler, KHÔNG dùng Direct Connection (chỉ IPv6, xem
# packages/database/.env.example để biết lý do chi tiết).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

NODE_ENV=development
PORT=3001

# JWT — generate strong random values for each environment
JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_TTL="7d"

# Frontend origin allowed by CORS
CORS_ORIGIN="http://localhost:3000"

# AI — OpenAI-compatible chat completions endpoint (Phase 4)
AI_API_BASE="https://your-router-host/v1"
AI_API_KEY="sk-change-me"
AI_MODEL="model-name"

# Telegram — tạo bot qua @BotFather để lấy TOKEN, lấy CHAT_ID bằng cách nhắn bot
# rồi gọi https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN="123456:change-me"
TELEGRAM_CHAT_ID="change-me"
