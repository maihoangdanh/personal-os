generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Module 001_auth
// ============================================================

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

/// Tenant boundary. Every User belongs to exactly one Workspace so the
/// data model is multi-tenant ready without a rewrite when team sharing arrives.
model Workspace {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(200)
  slug      String?   @unique @db.VarChar(120)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  users User[]

  @@map("workspaces")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @db.Uuid
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(200)
  passwordHash String?   @db.VarChar(255)
  role         UserRole  @default(MEMBER)
  timezone     String    @default("Asia/Ho_Chi_Minh") @db.VarChar(64)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  visions           Vision[]
  tags              Tag[]
  attachments       Attachment[]
  habits            Habit[]
  calendarEvents    CalendarEvent[]
  wallets           Wallet[]
  budgets           Budget[]
  investments       Investment[]
  assets            Asset[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  aiConversations   AiConversation[]
  aiSummaries       AiSummary[]
  journals          Journal[]
  refreshTokens     RefreshToken[]
  netWorthSnapshots NetWorthSnapshot[]

  @@index([workspaceId])
  @@index([email])
  @@map("users")
}

// ============================================================
// Module 002_goal
// ============================================================

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED
  ARCHIVED
}

model Vision {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  title      String    @db.VarChar(255)
  targetYear Int?      @db.SmallInt
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime? @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  goals Goal[]

  @@index([userId])
  @@map("visions")
}

model Goal {
  id           String     @id @default(uuid()) @db.Uuid
  visionId     String     @db.Uuid
  title        String     @db.VarChar(255)
  targetValue  Decimal?   @db.Decimal(18, 2)
  currentValue Decimal    @default(0) @db.Decimal(18, 2)
  deadline     DateTime?  @db.Date
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?  @db.Timestamptz(6)

  vision   Vision    @relation(fields: [visionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  kpis     KPI[]
  projects Project[]

  @@index([visionId])
  @@index([status])
  @@index([deadline])
  @@map("goals")
}

/// Measurable indicator attached to a Goal. Fields inferred (doc 10 lists the
/// table but no columns); kept minimal.
model KPI {
  id           String    @id @default(uuid()) @db.Uuid
  goalId       String    @db.Uuid
  name         String    @db.VarChar(255)
  unit         String?   @db.VarChar(50)
  targetValue  Decimal?  @db.Decimal(18, 2)
  currentValue Decimal   @default(0) @db.Decimal(18, 2)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([goalId])
  @@map("kpis")
}

// ============================================================
// Module 003_project
// ============================================================

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id        String        @id @default(uuid()) @db.Uuid
  goalId    String        @db.Uuid
  title     String        @db.VarChar(255)
  status    ProjectStatus @default(PLANNING)
  progress  Decimal       @default(0) @db.Decimal(5, 2)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?     @db.Timestamptz(6)

  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  milestones Milestone[]
  tasks      Task[]

  @@index([goalId])
  @@index([status])
  @@map("projects")
}

/// Checkpoint within a Project. Fields inferred (no column list in doc 02/03/10).
/// `isCompleted` is backend-maintained per doc 02: set true when ALL its Tasks are DONE.
model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  title       String    @db.VarChar(255)
  dueDate     DateTime? @db.Timestamptz(6)
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@map("milestones")
}

// ============================================================
// Module 004_task
// ============================================================

enum TaskStatus {
  INBOX
  TODO
  DOING
  REVIEW
  DONE
  ARCHIVED
}

model Task {
  id             String     @id @default(uuid()) @db.Uuid
  projectId      String     @db.Uuid
  parentTaskId   String?    @db.Uuid
  milestoneId    String?    @db.Uuid // optional grouping under a Milestone (doc 02: "Task của Milestone")
  title          String     @db.VarChar(255)
  description    String?    @db.Text
  impact         Int        @db.SmallInt // 1-5 (CHECK enforced at app layer, see notes)
  urgency        Int        @db.SmallInt // 1-5 (CHECK enforced at app layer, see notes)
  priorityScore  Int?       @db.SmallInt // computed by backend (calculate_priority)
  status         TaskStatus @default(TODO)
  deadline       DateTime?  @db.Timestamptz(6)
  completedAt    DateTime?  @db.Timestamptz(6) // set when status -> DONE (Business Rule doc 02)
  estimateMinute Int? // estimated effort in minutes; app validates >= 0 (doc 02). spentMinute derived from TimeLog.
  createdAt      DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?  @db.Timestamptz(6)

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  parentTask  Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subTasks    Task[]       @relation("TaskSubtasks")
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  checklists  Checklist[]
  timeLogs    TimeLog[]
  taskTags    TaskTag[]
  attachments Attachment[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([milestoneId])
  @@index([status])
  @@index([deadline])
  @@map("tasks")
}

/// Checklist item under a Task. Fields inferred (doc 03 states Task 1-N Checklist, no columns).
model Checklist {
  id        String    @id @default(uuid()) @db.Uuid
  taskId    String    @db.Uuid
  title     String    @db.VarChar(255)
  isDone    Boolean   @default(false)
  position  Int       @default(0) @db.SmallInt
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId])
  @@map("checklists")
}

/// Time tracking entry under a Task. Fields inferred (doc 03 states Task 1-N TimeLog, no columns).
model TimeLog {
  id              String    @id @default(uuid()) @db.Uuid
  taskId          String    @db.Uuid
  startTime       DateTime  @db.Timestamptz(6)
  endTime         DateTime? @db.Timestamptz(6)
  durationMinutes Int?
  note            String?   @db.Text
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId])
  @@map("timelogs")
}

/// Personal label owned by a User. Fields inferred.
model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  name      String    @db.VarChar(100)
  color     String?   @db.VarChar(20)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  taskTags TaskTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

/// Explicit join table Task <-> Tag. Pure link table: hard-delete on unlink
/// (no soft-delete column) so the unique pair does not leak a dead slot.
model TaskTag {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
  @@map("task_tags")
}

/// File attachment owned by a User, optionally linked to a Task. Fields inferred.
model Attachment {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  taskId    String?   @db.Uuid
  fileName  String    @db.VarChar(255)
  fileUrl   String    @db.Text
  fileType  String?   @db.VarChar(100)
  fileSize  Int?
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user User  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([taskId])
  @@map("attachments")
}

// ============================================================
// Module 005_habit (daily: habit tracking + calendar)
// ============================================================

/// Recurring habit owned by a User. Fields inferred (doc 10 lists table, no columns).
/// frequency kept as free String (e.g. DAILY/WEEKLY) — not one of the 7 mandated enums.
model Habit {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  frequency       String    @default("DAILY") @db.VarChar(20)
  targetPerPeriod Int       @default(1) @db.SmallInt
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6)

  user User       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

/// One check-in for a Habit on a given date. Fields inferred. One log per habit per day.
model HabitLog {
  id        String    @id @default(uuid()) @db.Uuid
  habitId   String    @db.Uuid
  logDate   DateTime  @db.Date
  value     Int       @default(1) @db.SmallInt
  note      String?   @db.Text
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([habitId, logDate])
  @@index([habitId])
  @@map("habit_logs")
}

/// Calendar event owned by a User. Fields inferred (doc 10 lists table, no columns).
model CalendarEvent {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  startTime   DateTime  @db.Timestamptz(6)
  endTime     DateTime? @db.Timestamptz(6)
  location    String?   @db.VarChar(255)
  allDay      Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([startTime])
  @@map("calendar_events")
}

// ============================================================
// Module 006_finance
// ============================================================

enum WalletType {
  CASH
  BANK
  CREDIT_CARD
  E_WALLET
  SAVINGS
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Wallet {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  name      String     @db.VarChar(100)
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(18, 2) // maintained by backend on transaction changes
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?  @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("wallets")
}

/// Spending budget owned by a User. Fields inferred (doc 10 lists table, no columns).
model Budget {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  name      String    @db.VarChar(100)
  category  String?   @db.VarChar(100) // free-text category this budget caps; matches Transaction.category (confirmed by user)
  amount    Decimal   @db.Decimal(18, 2)
  period    String    @default("MONTHLY") @db.VarChar(20)
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("budgets")
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  walletId        String          @db.Uuid
  type            TransactionType
  amount          Decimal         @db.Decimal(18, 2)
  description     String?         @db.VarChar(255)
  category        String?         @db.VarChar(100) // free-text category (e.g. Food, Salary); user-typed, no fixed enum (confirmed by user)
  transactionDate DateTime        @db.Timestamptz(6)
  transferGroupId String?         @db.Uuid // both legs of a wallet->wallet transfer share this id (doc 02: "Transfer sinh giao dịch trừ và cộng"). NULL = normal income/expense.
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime?       @db.Timestamptz(6)

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([transactionDate])
  @@index([transferGroupId])
  @@index([category])
  @@map("transactions")
}

/// Investment holding owned by a User. Fields inferred (doc 10 lists table, no columns).
model Investment {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  name         String    @db.VarChar(255)
  type         String?   @db.VarChar(50)
  amount       Decimal   @db.Decimal(18, 2)
  currentValue Decimal?  @db.Decimal(18, 2)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("investments")
}

/// Owned asset (net-worth item), owned by a User. Fields inferred. Distinct from
/// Attachment (a file) — Asset here is a financial/net-worth entry.
model Asset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  name      String    @db.VarChar(255)
  type      String?   @db.VarChar(50)
  value     Decimal   @db.Decimal(18, 2)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("assets")
}

// ============================================================
// Module 007_notification (notifications + audit/activity log)
// ============================================================

enum NotificationType {
  REMINDER
  DEADLINE
  SYSTEM
  ACHIEVEMENT
}

/// Notification / Reminder (a Reminder = Notification with type REMINDER; no separate table).
/// read/unread, scheduledFor+sentAt (Business Rule "gửi một lần cho mỗi mốc thời gian"),
/// snoozedUntil (Business Rule "Có thể Snooze") are grounded in doc 02 Notification Rules.
/// relatedEntity* is a loose pointer to what the notification is about (INFERRED — for the
/// Reminder module to link a reminder to a Task/CalendarEvent/Habit; not mandated by doc 02).
model Notification {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid
  type              NotificationType
  title             String           @db.VarChar(255)
  message           String?          @db.Text
  isRead            Boolean          @default(false)
  readAt            DateTime?        @db.Timestamptz(6)
  scheduledFor      DateTime?        @db.Timestamptz(6) // time point the reminder should fire
  sentAt            DateTime?        @db.Timestamptz(6) // null = not yet delivered; enforces send-once
  snoozedUntil      DateTime?        @db.Timestamptz(6) // set when user snoozes
  relatedEntityType String?          @db.VarChar(50) // e.g. "Task", "CalendarEvent", "Habit" (inferred)
  relatedEntityId   String?          @db.Uuid
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?        @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([type])
  @@index([scheduledFor])
  @@map("notifications")
}

/// Audit trail (doc 03 rule: "Audit Log cho mọi thay đổi quan trọng"). Append-only
/// in practice; keeps the standard timestamp columns for schema consistency.
/// entityType/entityId are a loose polymorphic pointer, metadata holds the diff.
model ActivityLog {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  action     String    @db.VarChar(100)
  entityType String?   @db.VarChar(100)
  entityId   String?   @db.Uuid
  metadata   Json?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// ============================================================
// Module 014_ai (Phase 4 — Intelligence)
// ------------------------------------------------------------
// doc 07 is conceptual only (no field-level schema). Only two things need
// persistence: AI Chat history and the LLM-generated periodic summaries.
// The other AI modules (Smart Planning, Priority Scoring, Finance Insight,
// Goal Prediction, Habit Coach) are RUNTIME suggestions over existing data —
// no table; accepted suggestions write to existing models (Task/CalendarEvent).
// All fields here are inferred (doc 07 gives none) — kept minimal.
// ============================================================

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

/// AI Summary type = doc 07 modules Daily Brief / Weekly Review / Monthly Review.
enum AiSummaryType {
  DAILY
  WEEKLY
  MONTHLY
}

/// One AI Chat thread owned by a User (doc 07 §4 "AI Chat").
model AiConversation {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  title     String?   @db.VarChar(255) // first question or auto-generated label
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user     User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  messages AiMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

/// One message in an AI Chat thread. `metadata` (Json) holds model name, token
/// usage, tool calls, confirmation state, etc. — flexible, not fixed columns.
model AiMessage {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @db.Uuid
  role           AiMessageRole
  content        String        @db.Text
  metadata       Json?
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?     @db.Timestamptz(6)

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

/// Stored LLM-generated periodic summary (Daily Brief / Weekly / Monthly Review).
/// STORED (not runtime) because the output is non-deterministic + token-costly and
/// is a point-in-time artifact — unlike the deterministic finance Monthly Report.
/// `content` = the generated text; `metadata` = the metrics behind it (hours, tasks
/// done, goal/project progress, spend, habit score — doc 07 §7/§8).
model AiSummary {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid
  type        AiSummaryType
  periodStart DateTime      @db.Date
  periodEnd   DateTime      @db.Date
  content     String        @db.Text
  metadata    Json?
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?     @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, type, periodStart]) // one summary per user per type per period (supports upsert on regenerate)
  @@index([userId])
  @@index([type])
  @@map("ai_summaries")
}

// ============================================================
// Module 015_journal (Daily > Journal) — late addition to Phase 1
// ------------------------------------------------------------
// Không có spec field-level ở bất kỳ doc nào (doc 01 PRD không có mục Journal;
// chỉ doc 07 §2 liệt kê "Journal" là nguồn dữ liệu AI). Fields inferred, tối thiểu.
// One entry per day (@@unique[userId,date]) — "Daily Journal", theo tiền lệ HabitLog.
// mood = String? (không enum) để tránh khoá cứng thang mood chưa được định nghĩa.
// ============================================================

model Journal {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  date      DateTime  @db.Date
  content   String    @db.Text
  mood      String?   @db.VarChar(50) // free-text (e.g. "great"/"good"/"neutral"/"bad"); app owns the set
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, date]) // one journal entry per user per day
  @@index([userId])
  @@map("journals")
}

// ============================================================
// Module 016_refresh_token (auth hardening — stateful refresh tokens)
// ------------------------------------------------------------
// Makes refresh tokens revocable so a leaked token can be killed before its
// 7d TTL expires (previously refresh was stateless JWT — no revoke possible).
// Store ONLY the SHA-256 hash of the token, never the plaintext (backend hashes
// before insert/compare). One User can hold MANY active tokens at once (multiple
// devices/tabs) — intentionally NOT a 1-1 relation with User.
// Deliberately NO deletedAt/updatedAt: this is ephemeral session state, not user
// data to preserve (like TaskTag). `revokedAt` marks invalidation; expired rows
// are hard-cleaned by a cleanup job. onDelete: Cascade — deleting a User drops
// their tokens (they carry no standalone value once the owner is gone).
// ============================================================

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(64) // SHA-256 hex digest of the refresh token (lookup on refresh)
  expiresAt DateTime  @db.Timestamptz(6) // mirrors JWT_REFRESH_TTL (7d); used for cleanup + expiry check
  revokedAt DateTime? @db.Timestamptz(6) // null = still valid; set on logout/revoke
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================
// Module 017_networth_snapshot (Dashboard Net Worth trend)
// ------------------------------------------------------------
// Persists a monthly point-in-time snapshot of Net Worth so the Dashboard can
// show real month-over-month % change + a 12-month trend chart (the design
// mockup's "+6.8% vs last month" badge + bar chart were hardcoded fakes with no
// API behind them). Net Worth itself is computed at runtime from Wallet/
// Investment/Asset (see _workspace/11_database_finance.md §6); this table only
// stores the historical value per month.
// One row per user per month (@@unique[userId, month]); the backend UPSERTS it
// repeatedly during the month to keep the latest value (not insert-only), so
// `updatedAt` tracks the last recompute. `month` is "YYYY-MM" text.
// Money fields use Decimal(18,2) — identical to Wallet.balance /
// Investment.currentValue / Asset.value so totals stay unit/precision-consistent.
// ============================================================

model NetWorthSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  month           String   @db.VarChar(7) // "YYYY-MM"
  netWorth        Decimal  @db.Decimal(18, 2) // Σ walletTotal + investmentTotal + assetTotal at snapshot time
  walletTotal     Decimal  @db.Decimal(18, 2) // Σ Wallet.balance
  investmentTotal Decimal  @db.Decimal(18, 2) // Σ Investment.currentValue
  assetTotal      Decimal  @db.Decimal(18, 2) // Σ Asset.value
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, month]) // one snapshot per user per month; also serves "latest N months of a user" (WHERE userId=? ORDER BY month DESC LIMIT N) — no separate @@index needed (would duplicate this b-tree)
  @@map("networth_snapshots")
}
